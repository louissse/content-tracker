generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContentItem {
  id        Int      @id @default(autoincrement())
  title     String
  status    String   @default("IDEA")  // IDEA | DRAFT | REVIEW | PUBLISHED | ARCHIVED
  authors   String                     // JSON-array, f.eks. '["andreas","maria"]'
  deadline  DateTime
  type      String                     // ARTICLE | VIDEO | PODCAST | OTHER
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
